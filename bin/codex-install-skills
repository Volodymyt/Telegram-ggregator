#!/usr/bin/env bash

set -euo pipefail

readonly SCRIPT_PATH="${BASH_SOURCE[0]}"
readonly SCRIPT_DIR="$(cd -- "${SCRIPT_PATH%/*}" && pwd)"
readonly REPO_ROOT="$(cd -- "${SCRIPT_DIR}/.." && pwd)"
readonly REPO_SKILLS_DIR="${REPO_ROOT}/.codex/skills"
readonly DEFAULT_CODEX_HOME="${HOME}/.codex"
readonly INSTALL_ROOT="${CODEX_HOME:-${DEFAULT_CODEX_HOME}}"
readonly INSTALL_SKILLS_DIR="${INSTALL_ROOT}/skills"
readonly VALIDATOR="${HOME}/.codex/skills/.system/skill-creator/scripts/quick_validate.py"

usage() {
  cat <<'EOF'
Usage:
  bin/codex-install-skills [skill-name ...]

Install repo skills from .codex/skills into $CODEX_HOME/skills.
If CODEX_HOME is not set, installs into ~/.codex/skills.

Examples:
  bin/codex-install-skills
  bin/codex-install-skills sync-docs-ua-translations
  CODEX_HOME=/tmp/codex-home bin/codex-install-skills
EOF
}

fail() {
  printf 'Error: %s\n' "$1" >&2
  exit 1
}

is_repo_skill() {
  local skill_name=$1
  local skill_dir="${REPO_SKILLS_DIR}/${skill_name}"

  [[ -d "${skill_dir}" && -f "${skill_dir}/SKILL.md" ]]
}

collect_all_repo_skills() {
  local skill_dir
  local skill_name

  shopt -s nullglob
  for skill_dir in "${REPO_SKILLS_DIR}"/*; do
    [[ -d "${skill_dir}" ]] || continue
    skill_name=$(basename "${skill_dir}")
    [[ "${skill_name}" == .* ]] && continue
    [[ -f "${skill_dir}/SKILL.md" ]] || continue
    printf '%s\n' "${skill_name}"
  done
  shopt -u nullglob
}

if (($# > 0)); then
  case "${1}" in
    -h|--help)
      usage
      exit 0
      ;;
  esac
fi

[[ -d "${REPO_SKILLS_DIR}" ]] || fail "repo skills directory not found: ${REPO_SKILLS_DIR}"
command -v python3 >/dev/null 2>&1 || fail "\`python3\` was not found in PATH"
[[ -f "${VALIDATOR}" ]] || fail "validator script not found: ${VALIDATOR}"

selected_skills=()

if (($# == 0)); then
  while IFS= read -r skill_name; do
    [[ -n "${skill_name}" ]] || continue
    selected_skills+=("${skill_name}")
  done < <(collect_all_repo_skills)
else
  for skill_name in "$@"; do
    is_repo_skill "${skill_name}" || fail "unknown repo skill: ${skill_name}"
    selected_skills+=("${skill_name}")
  done
fi

((${#selected_skills[@]} > 0)) || fail "no repo skills found in ${REPO_SKILLS_DIR}"

printf 'Installing repo skills into %s\n' "${INSTALL_SKILLS_DIR}"

for skill_name in "${selected_skills[@]}"; do
  skill_dir="${REPO_SKILLS_DIR}/${skill_name}"
  printf 'Validating %s\n' "${skill_name}"
  python3 "${VALIDATOR}" "${skill_dir}" >/dev/null
done

mkdir -p "${INSTALL_SKILLS_DIR}"

for skill_name in "${selected_skills[@]}"; do
  source_dir="${REPO_SKILLS_DIR}/${skill_name}"
  target_dir="${INSTALL_SKILLS_DIR}/${skill_name}"

  printf 'Installing %s\n' "${skill_name}"
  printf '  source: %s\n' "${source_dir}"
  printf '  target: %s\n' "${target_dir}"

  rm -rf "${target_dir}"
  cp -R "${source_dir}" "${target_dir}"
done

printf 'Installed %d skill(s).\n' "${#selected_skills[@]}"
printf 'Restart Codex to pick up new skills.\n'
