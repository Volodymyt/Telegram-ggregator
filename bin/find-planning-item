#!/usr/bin/env python3
"""Resolve canonical planning items by Planning ID."""

from __future__ import annotations

import argparse
import json
import re
import sys
from dataclasses import dataclass
from pathlib import Path
from typing import Iterable


PLANNING_ID_RE = re.compile(r"^Planning ID:\s*(\d{4})\s*$", re.MULTILINE)
STATUS_RE = re.compile(r"^Status:\s*(.+?)\s*$", re.MULTILINE)
TITLE_RE = re.compile(r"^#\s+(.+?)\s*$", re.MULTILINE)
CANONICAL_FILE_RE = re.compile(r"^\d{4}_[a-z0-9_]+\.md$")
TASK_FILE_RE = re.compile(r"^\d{2}_\d{4}_[a-z0-9_]+\.md$")


@dataclass(frozen=True)
class PlanningItem:
    planning_id: str
    title: str
    status: str
    kind: str
    path: Path
    location: str

    def to_dict(self, repo_root: Path) -> dict[str, object]:
        return {
            "planning_id": self.planning_id,
            "title": self.title,
            "status": self.status,
            "kind": self.kind,
            "path": str(self.path.relative_to(repo_root)),
            "location": self.location,
        }


class PlanningLookupError(Exception):
    """Raised when planning lookup fails."""


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Resolve a canonical planning item by Planning ID.",
    )
    parser.add_argument("planning_id", help="Planning ID, for example 0009 or 9")
    parser.add_argument(
        "--json",
        action="store_true",
        dest="json_output",
        help="Emit machine-readable JSON",
    )
    parser.add_argument(
        "--repo-root",
        type=Path,
        default=Path(__file__).resolve().parents[1],
        help=argparse.SUPPRESS,
    )
    return parser.parse_args()


def normalize_planning_id(raw_value: str) -> str:
    if not raw_value.isdigit():
        raise PlanningLookupError(f"Planning ID must be numeric, got: {raw_value}")
    normalized = raw_value.zfill(4)
    if len(normalized) != 4:
        raise PlanningLookupError(
            f"Planning ID must fit into four digits, got: {raw_value}"
        )
    return normalized


def iter_markdown_files(root: Path) -> Iterable[Path]:
    if not root.exists():
        return []
    return sorted(path for path in root.rglob("*.md") if path.is_file())


def load_text(path: Path) -> str:
    try:
        return path.read_text(encoding="utf-8")
    except OSError as exc:
        raise PlanningLookupError(f"Failed to read {path}: {exc}") from exc


def extract_required(pattern: re.Pattern[str], text: str, label: str, path: Path) -> str:
    match = pattern.search(text)
    if match is None:
        raise PlanningLookupError(f"Missing {label} in {path}")
    return match.group(1).strip()


def classify_kind(path: Path, repo_root: Path) -> str:
    relative = path.relative_to(repo_root / "docs" / "planning")
    parts = relative.parts

    if len(parts) >= 4 and parts[0] in {"active", "archive"} and parts[-2] == "tasks":
        if TASK_FILE_RE.fullmatch(path.name):
            return "task"

    if len(parts) >= 3 and parts[0] in {"active", "archive"}:
        if CANONICAL_FILE_RE.fullmatch(path.name):
            parent_dir = parts[-2]
            if re.fullmatch(r"\d{2}_\d{4}_[a-z0-9_]+", parent_dir):
                grandparent = parts[-3] if len(parts) >= 3 else ""
                if grandparent == "active" or grandparent == "archive":
                    return "epic"
                return "story"

    raise PlanningLookupError(f"Cannot classify canonical planning kind for {path}")


def load_item(path: Path, repo_root: Path, location: str) -> PlanningItem:
    text = load_text(path)
    planning_id = extract_required(PLANNING_ID_RE, text, "Planning ID", path)
    title = extract_required(TITLE_RE, text, "title", path)
    status = extract_required(STATUS_RE, text, "status", path)
    kind = classify_kind(path, repo_root)
    return PlanningItem(
        planning_id=planning_id,
        title=title,
        status=status,
        kind=kind,
        path=path,
        location=location,
    )


def is_canonical_candidate(path: Path, repo_root: Path) -> bool:
    try:
        classify_kind(path, repo_root)
    except PlanningLookupError:
        return False
    return True


def find_matches(repo_root: Path, planning_id: str) -> list[PlanningItem]:
    planning_root = repo_root / "docs" / "planning"
    matches: list[PlanningItem] = []

    for location in ("active", "archive"):
        location_root = planning_root / location
        for path in iter_markdown_files(location_root):
            if not is_canonical_candidate(path, repo_root):
                continue
            text = load_text(path)
            ids = PLANNING_ID_RE.findall(text)
            if not ids:
                continue
            if len(ids) > 1:
                raise PlanningLookupError(f"Multiple Planning ID entries found in {path}")
            if ids[0] != planning_id:
                continue
            matches.append(load_item(path, repo_root, location))

    return matches


def resolve_parent_item(item: PlanningItem, repo_root: Path) -> PlanningItem | None:
    if item.kind == "epic":
        return None

    parent_dir = item.path.parent.parent
    expected_id = parent_dir.name.split("_", 2)[1]
    candidate = parent_dir / f"{expected_id}_{parent_dir.name.split('_', 2)[2]}.md"
    if not candidate.exists():
        raise PlanningLookupError(f"Missing canonical parent document for {item.path}")

    return load_item(candidate, repo_root, item.location)


def build_output(item: PlanningItem, repo_root: Path) -> dict[str, object]:
    output = item.to_dict(repo_root)
    parents: dict[str, object] = {}

    if item.kind == "task":
        story = resolve_parent_item(item, repo_root)
        assert story is not None
        epic = resolve_parent_item(story, repo_root)
        assert epic is not None
        parents["story"] = story.to_dict(repo_root)
        parents["epic"] = epic.to_dict(repo_root)
    elif item.kind == "story":
        epic = resolve_parent_item(item, repo_root)
        assert epic is not None
        parents["epic"] = epic.to_dict(repo_root)

    output["parents"] = parents
    return output


def format_human_output(payload: dict[str, object]) -> str:
    lines = [
        f"Planning ID: {payload['planning_id']}",
        f"Title: {payload['title']}",
        f"Kind: {payload['kind']}",
        f"Status: {payload['status']}",
        f"Location: {payload['location']}",
        f"Path: {payload['path']}",
    ]

    parents = payload.get("parents", {})
    if isinstance(parents, dict):
        epic = parents.get("epic")
        if isinstance(epic, dict):
            lines.append(
                "Epic: "
                f"{epic['planning_id']} | {epic['status']} | {epic['title']} | {epic['path']}"
            )
        story = parents.get("story")
        if isinstance(story, dict):
            lines.append(
                "Story: "
                f"{story['planning_id']} | {story['status']} | {story['title']} | {story['path']}"
            )

    return "\n".join(lines)


def main() -> int:
    args = parse_args()
    repo_root = args.repo_root.resolve()

    try:
        planning_id = normalize_planning_id(args.planning_id)
        matches = find_matches(repo_root, planning_id)
        if not matches:
            raise PlanningLookupError(f"Planning item {planning_id} was not found")
        if len(matches) > 1:
            paths = ", ".join(str(match.path.relative_to(repo_root)) for match in matches)
            raise PlanningLookupError(
                f"Planning item {planning_id} is duplicated across: {paths}"
            )

        payload = build_output(matches[0], repo_root)
    except PlanningLookupError as exc:
        print(f"Error: {exc}", file=sys.stderr)
        return 1

    if args.json_output:
        print(json.dumps(payload, indent=2, sort_keys=True))
    else:
        print(format_human_output(payload))

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
