# Dry-run bootstrap profile for local config and bootstrap verification.
# Set DRY_RUN=0 and fill TG_API_ID, TG_API_HASH, and TARGET_CHANNEL before
# using Telegram-backed startup or the dedicated login command.
TG_API_ID=
TG_API_HASH=
TG_SESSION_PATH=/var/app/sessions/default.session
DATABASE_URL=postgresql+asyncpg://tgbot:tgbot_secret@postgres:5432/tgbot_db
TARGET_CHANNEL=
CONFIG_PATH=/var/app/config.example.yaml
LOG_LEVEL=INFO
DRY_RUN=1

# Compose-only Postgres variables.
POSTGRES_USER=tgbot
POSTGRES_PASSWORD=tgbot_secret
POSTGRES_DB=tgbot_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
